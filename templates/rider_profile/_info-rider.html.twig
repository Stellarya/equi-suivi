{% import "macros/macros.html.twig" as macros %}

<aside class="app-info-card details-info-card">
	{{ macros.modalButton(
		'edit-rider-profile',
		'general.edit',
		'fa-solid fa-pen',
		'rider-profile-edit-modal',
		'details-info-card__edit-link'
	) }}

	<div class="app-info-card__avatar">
		<i class="fa-solid fa-user" aria-hidden="true"></i>
	</div>

	<div class="app-info-card__identity">
		<h2>{{ rider.fullName }}</h2>
		<p>{{ 'rider.rider' | trans }}</p>
	</div>

	<dl class="app-info-card__details">
		<div>
			<dt>{{ 'rider.firstName' | trans }}</dt>
			<dd>{{ rider.firstName }}</dd>
		</div>

		<div>
			<dt>{{ 'rider.lastName' | trans }}</dt>
			<dd>{{ rider.lastName }}</dd>
		</div>

		<div>
			<dt>{{ 'rider.email' | trans }}</dt>
			<dd>{{ app.user.email }}</dd>
		</div>

		<div class="app-info-card__separator"></div>

		<div>
			<dt>{{ 'rider.lastGalop' | trans }}</dt>
			<dd>
				{% if lastGalop %}
					{{ lastGalop.galop.libelle }}
				{% else %}
					{{ 'rider.no_info' | trans }}
				{% endif %}
			</dd>
		</div>

		<div>
			<dt>{{ 'rider.obtentionYear' | trans }}</dt>
			<dd>
				{% if lastGalop and lastGalop.obtainedYear %}
					{{ lastGalop.obtainedYear }}
				{% else %}
					{{ 'rider.no_info' | trans }}
				{% endif %}
			</dd>
		</div>
	</dl>
</aside>
