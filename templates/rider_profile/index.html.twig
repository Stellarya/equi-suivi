{% extends "base.html.twig" %}

{% block title %}
	{{ 'rider.profile' | trans }}
{% endblock %}

{% block body %}
	<section id="rider" class="details-page">
		<div class="details-page__header">
			<h1>{{ 'rider.profile' | trans }}</h1>
		</div>

		{% if rider is null or rider is not defined %}
			<div class="details-page__empty">
				{{ 'rider.no_rider' | trans }}
			</div>
		{% else %}
			<div class="details-page__layout">
				{% include "rider_profile/_info-rider.html.twig" with {
					rider: rider,
					lastGalop: lastGalop
				} %}

				<section class="details-panel">
					{% include "rider_profile/_tabs.html.twig" %}

					<div class="details-panel__content">
						<div class="details-tab-content details-tab-content--active" id="tab-galops">
							{% include "rider_profile/_tab-galops.html.twig" with {
								galopHistory: galopHistory,
								riderGalopEditForms: riderGalopEditForms,
								openRiderGalopEditModalId: openRiderGalopEditModalId|default(null)
							} %}
						</div>
					</div>
				</section>
			</div>

			{% include "rider_profile/_edit-profile-modal.html.twig" with {
				form: form,
				isProfileModalOpen: isProfileModalOpen|default(false)
			} %}

			{% include "rider_galop/_rider-galop-modal.html.twig" with {
				modalId: 'rider-galop-add-modal',
				modalTitle: 'rider.add_galop',
				form: riderGalopForm,
				isOpen: isRiderGalopModalOpen|default(false)
			} %}
		{% endif %}
	</section>
{% endblock %}
