<div id="rider-profile-edit-modal" class="rider-modal {% if isProfileModalOpen %}is-open{% endif %}" aria-hidden="{{ isProfileModalOpen ? 'false' : 'true' }}" data-modal>
	<div class="rider-modal__overlay" data-modal-close></div>

	<div class="rider-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="rider-profile-edit-modal-title">
		<div class="rider-modal__header">
			<h2 id="rider-profile-edit-modal-title">
				{{ 'rider.edit_profile' | trans }}
			</h2>

			<button type="button" class="rider-modal__close" aria-label="Fermer" data-modal-close>
				<i class="fa-solid fa-xmark"></i>
			</button>
		</div>

		{{ form_start(form, {
            attr: {
                class: 'rider-modal__form'
            }
        }) }}

		<div class="rider-modal__body">
			<div class="rider-modal__field">
				{{ form_label(form.firstName) }}
				{{ form_widget(form.firstName) }}
				{{ form_errors(form.firstName) }}
			</div>

			<div class="rider-modal__field">
				{{ form_label(form.lastName) }}
				{{ form_widget(form.lastName) }}
				{{ form_errors(form.lastName) }}
			</div>
		</div>

		<div class="rider-modal__footer">
			<button type="button" class="rider-modal__button rider-modal__button--secondary" data-modal-close>
				Annuler
			</button>

			<button type="submit" class="rider-modal__button rider-modal__button--primary">
				Enregistrer
			</button>
		</div>

		{{ form_end(form) }}
	</div>
</div>
