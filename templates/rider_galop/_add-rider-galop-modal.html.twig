<div id="rider-galop-add-modal" class="rider-modal {% if isRiderGalopModalOpen %}is-open{% endif %}" aria-hidden="{{ isRiderGalopModalOpen ? 'false' : 'true' }}" data-modal>
	<div class="rider-modal__overlay" data-modal-close></div>

	<div class="rider-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="rider-galop-add-modal-title">
		<div class="rider-modal__header">
			<h2 id="rider-galop-add-modal-title">
				{{ 'rider.add_galop' | trans }}
			</h2>

			<button type="button" class="rider-modal__close" aria-label="Fermer" data-modal-close>
				<i class="fa-solid fa-xmark"></i>
			</button>
		</div>

		{{ form_start(riderGalopForm, {
            attr: {
                class: 'rider-modal__form'
            }
        }) }}

		<div class="rider-modal__body">
			<div class="rider-modal__field">
				{{ form_label(riderGalopForm.galop) }}
				{{ form_widget(riderGalopForm.galop) }}
				{{ form_errors(riderGalopForm.galop) }}
			</div>

			<div class="rider-modal__field">
				{{ form_label(riderGalopForm.obtainedYear) }}
				{{ form_widget(riderGalopForm.obtainedYear) }}
				{{ form_errors(riderGalopForm.obtainedYear) }}
			</div>
		</div>

		<div class="rider-modal__footer">
			<button type="button" class="rider-modal__button rider-modal__button--secondary" data-modal-close>
				{{ 'actions.cancel' | trans }}
			</button>

			<button type="submit" class="rider-modal__button rider-modal__button--primary">
				{{ 'actions.save' | trans }}
			</button>
		</div>

		{{ form_end(riderGalopForm) }}
	</div>
</div>
