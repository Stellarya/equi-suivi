{% macro deleteButton(id, options = '') %}
	<a id="{{ button }}" class="btn btn-danger" data-value="{{ id }}" title="Supprimer {{ options }}" role="button">
		<i class="fas fa-trash"></i>
	</a>
{% endmacro %}
{% macro updateButton(id) %}
	<a id="{{ id }}" data-value="{{ id }}" title="Modifier" role="button" aria-expanded="false">
		<i class"fas fa-pencil"></i>
	</a>
{% endmacro %}
