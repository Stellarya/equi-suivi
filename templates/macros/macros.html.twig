{# left sidebar #}
{% macro navItem(icon, label, role, link, params = {}, idItem = null ) %}
	{% if is_granted(role) %}
		<div class="nav-item " title="{{ label }}" data-value="{{ label }}" {% if idItem != null %} id="{{ idItem }}" {% endif %}>

			<a {% if link != null %} href="{{ path(link, params) }}" {% endif %}>
				<i class="{{ icon }}"></i>
				<span>{{ label | trans}}</span>
			</a>
		</div>
	{% endif %}

{% endmacro %}
{# Tabs #}
{% macro navItemTabs(icon, label, link, active, params = {}) %}
	<li class="nav-item text-truncate">
		<a class="nav-link {{ active }} text-truncate" data-toggle="tab" href="#{{ link }}" title="{{ label }}">
			<i class="{{ icon }}"></i>
			<span class="d-none d-lg-inline text-truncate">{{ label }}</span>
		</a>
	</li>
{% endmacro %}

{# Buttons #}
{% macro button(datavalue, label, class, icon) %}
	<div data-value="{{ datavalue }}" class="btn {{ class }}">
		<i class="{{ icon }}"></i>
		{{ label }}
	</div>
{% endmacro %}

{% macro addButton(id, options = '') %}
	<button class="btn btn-primary px-0 btn-round d-none d-sm-block" id={{ id }} title="Ajouter {{ options }}">
		<i class="fa fa-plus"></i>
	</button>
{% endmacro %}
{% macro addButton(id, options = '') %}
	<button class="btn btn-primary px-0 btn-round d-none d-sm-block" id={{ id }} title="Ajouter {{ options }}">
		<i class="fa fa-plus"></i>
