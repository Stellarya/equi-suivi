<div id="{{ modalId }}" class="app-modal {% if isOpen %}is-open{% endif %}" aria-hidden="{{ isOpen ? 'false' : 'true' }}" data-modal>
	<div class="app-modal__overlay" data-modal-close></div>

	<div class="app-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="{{ modalId }}-title">
		<div class="app-modal__header">
			<h2 id="{{ modalId }}-title">
				{{ modalTitle | trans }}
			</h2>

			<button type="button" class="app-modal__close" aria-label="Fermer" data-modal-close>
				<i class="fa-solid fa-xmark"></i>
			</button>
		</div>

		{{ form_start(form, {
            attr: {
                class: 'app-modal__form'
            }
        }) }}

		<div class="app-modal__body">
			<div class="d-flex row">
				<div class="app-modal__field col-6">
					{{ form_label(form.name) }}
					{{ form_widget(form.name) }}
					{{ form_errors(form.name) }}
				</div>


				<div class="app-modal__field col-6">
					{{ form_label(form.affix) }}
					{{ form_widget(form.affix) }}
					{{ form_errors(form.affix) }}
				</div>
			</div>
			<div class="d-flex row">
				<div class="app-modal__field col-6">
					{{ form_label(form.birthDate) }}
					{{ form_widget(form.birthDate) }}
					{{ form_errors(form.birthDate) }}
				</div>

				<div class="app-modal__field col-6">
					{{ form_label(form.sire) }}
					{{ form_widget(form.sire) }}
					{{ form_errors(form.sire) }}
				</div>
			</div>
			<div class="d-flex row">
				<div class="app-modal__field col-6">
					{{ form_label(form.breed) }}
					{{ form_widget(form.breed) }}
					{{ form_errors(form.breed) }}
				</div>

				<div class="app-modal__field col-6">
					{{ form_label(form.coat) }}
					{{ form_widget(form.coat) }}
					{{ form_errors(form.coat) }}
				</div>
			</div>
			<div class="d-flex row">
				<div class="app-modal__field col-12">
					{{ form_label(form.disciplines) }}

					<!-- Conteneur personnalisé pour le système de tags -->
					<div class="custom-tag-select" data-tag-select>
						<div
							class="tag-container" data-tag-container><!-- Les tags sélectionnés apparaîtront ici via JS -->
						</div>

						<!-- Le widget Symfony générera un <select multiple> -->
						{{ form_widget(form.disciplines, { 'attr': {'class': 'd-none', 'data-tag-select-input': 'true'} }) }}

						<!-- Un select visible et épuré pour choisir les disciplines à ajouter -->
						<select class="form-control mt-2" data-tag-select-selector>
							<option value="">{{ 'horse.select_discipline' | trans }}</option>
							{% for choice in form.disciplines.vars.choices %}
								<option value="{{ choice.value }}">{{ choice.label }}</option>
							{% endfor %}
						</select>
					</div>

					{{ form_errors(form.disciplines) }}
				</div>
			</div>
			<div class="d-flex row">
				<div class="app-modal__field col-6">
					{{ form_label(form.photo) }}
					{{ form_widget(form.photo) }}
					{{ form_errors(form.photo) }}
				</div>

				<div class="app-modal__field col-6">
					{{ form_label(form.status) }}
					{{ form_widget(form.status) }}
					{{ form_errors(form.status) }}
				</div>
			</div>
		</div>
		<div class="app-modal__footer">
			<button type="button" class="app-modal__button app-modal__button--secondary" data-modal-close>
				{{ 'actions.cancel' | trans }}
			</button>

			<button type="submit" class="app-modal__button app-modal__button--primary">
				{{ 'actions.save' | trans }}
			</button>
		</div>

		{{ form_end(form) }}
	</div>
</div>
