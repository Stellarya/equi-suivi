{% set roleLabel = 'Cavalier' %}

{% if is_granted('ROLE_ADMIN') %}
	{% set roleLabel = 'Admin' %}
{% elseif is_granted('ROLE_ECURIE') %}
	{% set roleLabel = 'Écurie' %}
{% elseif is_granted('ROLE_USER') %}
	{% set roleLabel = 'Cavalier' %}
{% endif %}

{% set rider = app.user.rider ?? null %}

<header class="topbar">
	<div class="topbar__actions">
		<button class="topbar__notification" type="button" aria-label="Notifications">
			<i class="fa-solid fa-bell"></i>
			<span class="topbar__notification-badge">6</span>
		</button>

		<div class="topbar__profile-wrapper">
			<button class="topbar__profile" type="button" aria-label="Menu utilisateur">
				<span class="topbar__avatar">
					<i class="fa-solid fa-user"></i>
				</span>

				<span class="topbar__identity">
					<span class="topbar__name">
						{% if rider %}
							{{ rider.fullName }}
						{% else %}
							{{ app.user.email }}
						{% endif %}
					</span>

					<span class="topbar__role">
						{{ roleLabel }}
					</span>
				</span>

				<i class="fa-solid fa-chevron-down topbar__chevron"></i>
			</button>

			<div class="topbar__dropdown">
				<a href="{{ path('app_rider_profile') }}" class="topbar__dropdown-link">
					<i class="fa-solid fa-id-card"></i>
					<span>Mon profil</span>
				</a>

				<a href="{{ path('app_logout') }}" class="topbar__dropdown-link topbar__dropdown-link--danger">
					<i class="fa-solid fa-right-from-bracket"></i>
					<span>Se déconnecter</span>
				</a>
			</div>
		</div>
	</div>
</header>
